# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Mapbox — browser maps need the **web** token (pk.*), not the native token.
# Put local overrides in .env.local (gitignored). Restart `npm run dev` after changes (port 8080).
#
# Option A (production / Lovable): set MAPBOX_WEB_TOKEN on Supabase; maps load via get-mapbox-token.
# Option B (local dev): paste the same web pk token in .env.local:
# VITE_MAPBOX_WEB_TOKEN=pk.eyJ...
#
# VITE_MAPBOX_PUBLIC_TOKEN (if present in .env) is NOT used for admin maps — native token → 403 in browser.
